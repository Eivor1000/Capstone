# ========================================
# API Keys
# ========================================

# Groq API Key (Required for story generation, summarization, etc.)
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# YouTube Data API v3 Key (Optional - for educational video search)
# Get key at: https://console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key_here

# Note: Image generation uses Pollinations.ai (free, no API key needed!)
# Note: Kids Challenge uses local Qwen2-VL-2B-Instruct model (no API needed!)


# ========================================
# PostgreSQL Database Configuration
# ========================================

# Option 1: Full DATABASE_URL (recommended for production/Heroku)
DATABASE_URL=postgresql://username:password@localhost:5432/ai_creative_suite

# Option 2: Individual components (will be used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_creative_suite
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here


# ========================================
# JWT Authentication
# ========================================

# Secret key for JWT token signing (CHANGE THIS!)
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-to-random-string

# JWT Algorithm (don't change unless you know what you're doing)
JWT_ALGORITHM=HS256

# JWT Token expiry in hours
JWT_EXPIRY_HOURS=24


# ========================================
# Flask Configuration
# ========================================

# Flask environment: development, production, testing
FLASK_ENV=development

# Flask debug mode (set to False in production!)
FLASK_DEBUG=True

# Secret key for Flask sessions
FLASK_SECRET_KEY=another-super-secret-key-change-this


# ========================================
# Application Settings
# ========================================

# Server host and port
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173


# ========================================
# Development/Testing Flags
# ========================================

# Create test user on startup (only in development)
CREATE_TEST_USER=True

# Enable SQL query logging (useful for debugging)
SQLALCHEMY_ECHO=False
