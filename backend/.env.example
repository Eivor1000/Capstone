# Groq API Key (Get free key at: https://console.groq.com)
# Used for: Story generation, text processing, AND vision analysis (Kids Challenge)
# Groq's llama-3.2-11b-vision-preview model analyzes images for grading
GROQ_API_KEY=your_groq_api_key_here

# YouTube Data API v3 Key (Get free key at: https://console.cloud.google.com)
# Enable "YouTube Data API v3" in your Google Cloud project
# Free tier: 10,000 quota units/day = 100 searches/day
YOUTUBE_API_KEY=your_youtube_api_key_here

# Note: Image generation uses Pollinations.ai (free, no API key needed!)
